#!/usr/bin/env bash
# nb — wrapper for NetBox infrastructure scripts
#
# Loads .env automatically so you never type credentials.
# Usage:
#   nb sync compute --dry-run              # preview all compute asset tags
#   nb sync compute --filter potato        # program only potato nodes
#   nb sync compute                        # program all compute asset tags
#   nb sync pdus --dry-run                 # preview PDU asset tags
#   nb sync pdus --verified-only           # program verified PDUs only
#   nb query <device-name>                 # quick-check a device in NetBox
#   nb help                                # show this help
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ENV_FILE="${SCRIPT_DIR}/.env"

# ── Load environment ─────────────────────────────────────────────────────────
if [[ -f "$ENV_FILE" ]]; then
    set -a
    source "$ENV_FILE"
    set +a
else
    echo "ERROR: ${ENV_FILE} not found. Create it with NETBOX_URL, NETBOX_TOKEN, NETBOX_SSL_VERIFY."
    exit 1
fi

# ── Commands ─────────────────────────────────────────────────────────────────
cmd_sync() {
    local target="${1:-}"
    shift || true
    case "$target" in
        compute)
            python3 "${SCRIPT_DIR}/compute/sync_asset_tags.py" "$@"
            ;;
        pdus|pdu)
            python3 "${SCRIPT_DIR}/pdus/sync_asset_tags.py" "$@"
            ;;
        *)
            echo "Usage: nb sync {compute|pdus} [options]"
            echo ""
            echo "Compute options:"
            echo "  --dry-run              Preview changes without writing"
            echo "  --filter <pattern>     Only process matching entries (e.g. 'potato', 'ginger')"
            echo "  --hostnames-csv PATH   Custom CSV path"
            echo ""
            echo "PDU options:"
            echo "  --dry-run              Preview changes without writing"
            echo "  --verified-only        Only program serial-verified PDUs"
            echo "  --skip-live-verify     Trust CSV serials without HTTP check"
            exit 1
            ;;
    esac
}

cmd_query() {
    local name="${1:-}"
    if [[ -z "$name" ]]; then
        echo "Usage: nb query <device-name-or-pattern>"
        exit 1
    fi
    python3 -c "
import pynetbox, os, urllib3
urllib3.disable_warnings()
nb = pynetbox.api(os.environ['NETBOX_URL'], token=os.environ['NETBOX_TOKEN'])
nb.http_session.verify = False
found = False
for d in nb.dcim.devices.filter(name__ic='${name}'):
    found = True
    tag = d.asset_tag or '(none)'
    owner = (d.custom_fields or {}).get('owner') or '(none)'
    role = d.role.name if d.role else '?'
    name_str = d.name or '(unnamed)'
    print(f'{name_str:<55} tag={tag:<6} owner={str(owner):<10} role={role}  id={d.id}')
if not found:
    print(f'No devices matching \"${name}\"')
"
}

cmd_help() {
    echo "nb — NetBox infrastructure toolkit"
    echo ""
    echo "Commands:"
    echo "  nb sync compute [opts]    Sync compute asset tags from CSV → NetBox"
    echo "  nb sync pdus [opts]       Sync PDU asset tags from CSV → NetBox"
    echo "  nb query <pattern>        Quick-lookup devices by name substring"
    echo "  nb help                   Show this help"
    echo ""
    echo "Common workflows:"
    echo "  nb sync compute --filter potato --dry-run   # preview potato nodes"
    echo "  nb sync compute --filter potato             # program potato nodes"
    echo "  nb sync compute --dry-run                   # preview all compute"
    echo "  nb sync compute                             # program all compute"
    echo "  nb query ginger                             # check ginger servers"
}

# ── Dispatch ─────────────────────────────────────────────────────────────────
case "${1:-help}" in
    sync)   shift; cmd_sync "$@" ;;
    query)  shift; cmd_query "$@" ;;
    help|--help|-h) cmd_help ;;
    *)
        echo "Unknown command: $1"
        cmd_help
        exit 1
        ;;
esac
